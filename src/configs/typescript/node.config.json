{
    "extends": "@codefish/dev-configs/tsconfig.base",
    "compilerOptions": {
        "module": "NodeNext",
        "lib": ["es2022"],
        "types": ["node"],
        "paths": {
            "@/*": ["./src/*"]
        },
        "plugins": [
            {
                "name": "ts-plugin-sort-import-suggestions",
                // Prioritise `@/`, `../`, and `./`
                "moveUpPatterns": ["@/", "\\.{1,2}/"],
                "moveDownPatterns": ["dist"]
            }
        ]
    }
}
