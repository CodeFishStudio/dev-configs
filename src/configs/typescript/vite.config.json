{
    "extends": ["@codefish/dev-configs/tsconfig.base", "@codefish/dev-configs/tsconfig.reactWeb"],

    /* --------------------------------------------------------
     * FROM THE `create vite` TOOL
     * -------------------------------------------------------- */
    "compilerOptions": {
        "types": ["node", "vite/client"],
        "module": "ES2022",
        "moduleResolution": "bundler",
        "rootDirs": [".", "./.react-router/types"],
        "paths": {
            "@/*": ["./src/*"]
        },
        "plugins": [
            {
                "name": "ts-plugin-sort-import-suggestions",
                // Prioritise `@/`, `../`, `./`, and `react`
                "moveUpPatterns": ["@/", "\\.{1,2}/", "^react"],
                "moveDownPatterns": ["dist"]
            }
        ]
    },
    "include": ["**/*", "**/.server/**/*", "**/.client/**/*", ".react-router/types/**/*"]
}
