{
    "extends": ["expo/tsconfig.base", "@codefish/dev-configs/tsconfig.base"],
    "compilerOptions": {
        "lib": ["esnext"],
        "types": ["react", "react-native", "node"],
        "jsx": "react-jsx",
        "paths": {
            "@/assets/*": ["./assets/*"],
            "@/*": ["./src/*"]
        },
        "plugins": [
            {
                "name": "ts-plugin-sort-import-suggestions",
                // Prioritise `@/`, `../`, `./`, and `react-native`
                "moveUpPatterns": ["@/", "\\.{1,2}/", "^react-native$"],
                "moveDownPatterns": ["dist"]
            }
        ]
    }
}
