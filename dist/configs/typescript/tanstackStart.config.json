{
    "extends": ["@codefish/dev-configs/tsconfig.base", "@codefish/dev-configs/tsconfig.reactWeb"],

    /* --------------------------------------------------------
     * FROM THE `create @tanstack/start@latest` TOOL
     * -------------------------------------------------------- */
    "compilerOptions": {
        "module": "ESNext",
        "types": ["vite/client"],
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": false,
        "paths": {
            "@/*": ["./src/*"]
        },
        "plugins": [
            {
                "name": "ts-plugin-sort-import-suggestions",
                // Prioritise `@/`, `../`, `./`, and `react`
                "moveUpPatterns": ["@/", "\\.{1,2}/", "^react"],
                "moveDownPatterns": ["dist"]
            }
        ]
    },
    "include": ["**/*", "eslint.config.js", "vite.config.js"]
}
